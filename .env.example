# Skopiuj ten plik jako .env i uzupełnij dane.
# NIE commituj .env do repozytorium!

# ---- MyFitnessPal credentials ----------------------------------------
MFP_USERNAME=your_mfp_username_or_email
MFP_PASSWORD=your_mfp_password

# ---- MCP transport (streamable-http | sse | stdio) -------------------
MCP_TRANSPORT=streamable-http

# ---- Traefik — wymagane gdy używasz Traefika jako reverse proxy ------

# Domena, pod którą Traefik ma wystawiać serwer MCP
DOMAIN=mfp.twojadomena.pl

# Nazwa certresolvera skonfigurowanego w Traefiku (domyślnie letsencrypt)
CERT_RESOLVER=letsencrypt

# Nazwa zewnętrznej sieci Docker używanej przez Traefik
# (musi istnieć: docker network create traefik)
TRAEFIK_NETWORK=traefik
